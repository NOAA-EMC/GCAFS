#! /usr/bin/env bash

########## config.tropcy ##########
echo "BEGIN: config.tropcy"

# Tracker/genesis package location
export HOMEens_tracker=${BASE_GIT}/TC_tracker/${ens_tracker_ver}
export EXECens_tracker=${HOMEens_tracker}/exec
export FIXens_tracker=${HOMEens_tracker}/fix
export USHens_tracker=${HOMEens_tracker}/ush
export SCRIPTens_tracker=${HOMEens_tracker}/scripts
export BINens_tracker=${BINens_tracker:-${HOMEens_tracker}/ush/FSUgenesisPY/bin}
export PYTHONPATH=${USHens_tracker}/FSUgenesisPY:${PYTHONPATH}

export SENDCOM="YES" # Needed by tracker scripts still

export FHOUT_CYCLONE=6
FHMAX_CYCLONE=$(( FHMAX_GFS<240 ? FHMAX_GFS : 240 ))
export FHMAX_CYCLONE

echo "END: config.tropcy"
