#!/usr/bin/env bash

set -ux

CASE_NAME=${1:?"Name of the case is required"}
TEST_NAME=${2:?"Name of the test is required"}
TEST_DATE=${3:?"Date of the test is required"}
# CMake to fill these variables
CTESTS_STAGED_TESTS_DIR="@CTESTS_STAGED_TESTS_DIR@"
RUNTESTS="@RUNTESTS@"
HOMEgfs="@PROJECT_SOURCE_DIR@"

# Load the runtime environment for this script (needs wxflow and its dependencies)
set +x
source "${HOMEgfs}/dev/ush/gw_setup.sh"
rc=$?
if [[ "${rc}" -ne 0 ]]; then
   exit "${rc}"
fi
set -x
PYTHONPATH="${PYTHONPATH:+${PYTHONPATH}:}${HOMEgfs}/sorc/wxflow/src"
export PYTHONPATH

YAML_FILE="${HOMEgfs}/dev/ctests/cases/${TEST_NAME}.yaml"

# Find pslot with pattern CASE_NAME_<suffix> where suffix is typically a hash
PSLOT=$("${HOMEgfs}"/dev/ci/scripts/utils/ci_utils.sh get_pslot "${CTESTS_STAGED_TESTS_DIR}" "${CASE_NAME}")

PSLOT="${PSLOT}" \
RUNTESTS="${RUNTESTS}" \
TEST_NAME="${TEST_NAME}" \
CTESTS_STAGED_TESTS_DIR="${CTESTS_STAGED_TESTS_DIR}" \
"${HOMEgfs}/dev/ctests/scripts/stage.py" --yaml "${YAML_FILE}" --test_date "${TEST_DATE}"
rc=$?
if [[ "${rc}" -ne 0 ]]; then
    set +x
    echo "Failed to stage inputs for '${TEST_NAME}' with '${YAML_FILE}'"
    set -x
    exit "${rc}"
fi

exit 0
